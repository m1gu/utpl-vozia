      ],
      "id": "779f9188-9359-4f34-9088-812db3e11a3a",
      "name": "EXTRAE STRUCTURED OUTPUTS"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const cfg = $items('CONFIG INICIAL UTPL', 0, 0)[0].json.cfg;\n  const nom = String(item.json.nomenclatura || '').trim().toUpperCase();\n  const retryNoms = cfg.retryNomenclaturas || ['NC', 'VLL'];\n\n  if (retryNoms.includes(nom)) {\n    item.json.status_sugerido = 'REINTENTAR';\n    item.json.estado_flujo = cfg.states.retry;\n  } else {\n    item.json.status_sugerido = 'FINAL';\n    item.json.estado_flujo = cfg.states.done;\n  }\n\n  return item;\n});"
      },
