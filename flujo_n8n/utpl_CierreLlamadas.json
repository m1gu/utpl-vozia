    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    cfg: {\n      db: { schema: 'public', table: 'utpl_registros', pk: 'id_negocio' },\n      states: { pending: 'PENDIENTE', inProgress: 'EN_PROCESO', retry: 'REINTENTAR', done: 'FINALIZADO' },\n      retryNomenclaturas: ['NC', 'VLL'],\n      policy: { TZ: 'America/Guayaquil' },\n      phoneFields: ['telefono1', 'telefono2', 'telefono3', 'telefono4', 'telefono5', 'telefono6']\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1380,
        200
      ],
      "id": "fa1e3bff-8bd2-4c53-beea-048d7efe4213",
      "name": "CONFIG INICIAL UTPL"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const root = item.json || {};\n  const envelope = root.body && typeof root.body === 'object' ? root.body : root;\n  const msg = envelope.message || envelope.data || root.message || root.data || {};\n\n  const findDeep = (obj, predicate) => {\n    const seen = new Set();\n    const stack = [obj];\n    while (stack.length) {\n      const cur = stack.pop();\n      if (!cur || typeof cur !== 'object') continue;\n      if (seen.has(cur)) continue;\n      seen.add(cur);\n      if (predicate(cur)) return cur;\n      for (const v of Object.values(cur)) {\n        if (v && typeof v === 'object') stack.push(v);\n      }\n    }\n    return null;\n  };\n\n  const callObj = msg.call || envelope.call || root.call ||\n    findDeep(msg, (x) => x.id && (x.startedAt || x.endedAt || x.customer || x.metadata));\n\n  const metadata = (callObj && callObj.metadata) || msg.metadata || envelope.metadata || root.metadata || {};\n\n  const startedAt = (callObj && callObj.startedAt) || msg.startedAt || envelope.startedAt || root.startedAt || null;\n  const endedAt = (callObj && callObj.endedAt) || msg.endedAt || envelope.endedAt || root.endedAt || null;\n  const endedReason = msg.endedReason || envelope.endedReason || root.endedReason || null;\n  const eventType = msg.type || envelope.type || root.type || null;\n  const callId = (callObj && callObj.id) || msg.id || envelope.id || root.id || null;\n  const customer = (callObj && callObj.customer) || msg.customer || envelope.customer || root.customer || {};\n\n  const transcript = msg.transcript || envelope.transcript || root.transcript ||\n    (msg.artifact && msg.artifact.transcript) || null;\n  const recordingUrl = msg.recordingUrl || envelope.recordingUrl || root.recordingUrl ||\n    (msg.artifact && msg.artifact.recordingUrl) || null;\n  const summary = msg.summary || envelope.summary || root.summary || null;\n\n  const durationMs = msg.durationMs || envelope.durationMs || root.durationMs || null;\n  const durationSeconds = msg.durationSeconds || envelope.durationSeconds || root.durationSeconds ||\n    (durationMs ? Math.round(durationMs / 1000) : null);\n\n  const cost = msg.cost || envelope.cost || root.cost || 0;\n\n  const artifact = msg.artifact || envelope.artifact || root.artifact || {};\n  const structuredOutputs = artifact.structuredOutputs || msg.structuredOutputs ||\n    envelope.structuredOutputs || root.structuredOutputs || {};\n\n  const transfers = artifact.transfers || msg.transfers || envelope.transfers || root.transfers || [];\n\n  item.json = {\n    id_negocio: metadata.id_negocio || null,\n    cedula: metadata.cedula || null,\n    id_llamada: callId || null,\n    event_type: eventType,\n    endedReason: endedReason,\n    startedAt: startedAt,\n    endedAt: endedAt,\n    transcript: transcript,\n    recordingUrl: recordingUrl,\n    summary: summary,\n    durationMs: durationMs,\n    durationSeconds: durationSeconds,\n    cost: cost,\n    customer_number: customer.number || null,\n    customer_name: customer.name || null,\n    metadata: metadata,\n    artifact: artifact,\n    structuredOutputs: structuredOutputs,\n    transfers: transfers,\n    _raw: envelope\n  };\n  return item;\n});"
      },
