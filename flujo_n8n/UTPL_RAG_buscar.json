      "webhookId": "utpl-rag-buscar-wh"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const root = item.json.body || item.json || {};\n  const msg = root.message || root;\n\n  // Extraer toolCallId y arguments del formato Vapi\n  const toolCalls = msg.toolCallList || msg.toolCalls || [];\n  const firstCall = (Array.isArray(toolCalls) ? toolCalls[0] : toolCalls) || {};\n  const args = firstCall.function?.arguments || firstCall.arguments || {};\n  const toolCallId = firstCall.id || firstCall.toolCallId || root.toolCallId || '';\n\n  const pregunta = String(args.pregunta || root.pregunta || '').trim();\n  const modalidad = String(args.modalidad || root.modalidad || '').trim().toUpperCase();\n\n  if (!pregunta) {\n    item.json.toolCallId = toolCallId;\n    item.json.error = 'Falta el campo pregunta';\n    return item;\n  }\n\n  item.json.toolCallId = toolCallId;\n  item.json.pregunta_original = pregunta;\n  item.json.modalidad_filtro = modalidad || null;\n  item.json.openai_request = {\n    model: 'text-embedding-3-small',\n    input: pregunta\n  };\n  return item;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        140
      ],
      "id": "32c56144-fd3c-406f-a4c7-bc952eb6b4ca",
      "name": "PREPARA EMBEDDING"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
