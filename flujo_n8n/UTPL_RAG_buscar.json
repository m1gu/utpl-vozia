    {
      "parameters": {
        "jsCode": "return items.map(item => ({\n  json: {\n    results: [{\n      toolCallId: item.json.toolCallId || '',\n      result: 'Error: ' + (item.json.error || 'Falta la pregunta')\n    }]\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
