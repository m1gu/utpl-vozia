      "id": "fe72d192-0a0b-4362-a5d4-b1d2652d2211",
      "name": "OPENAI EMBEDDINGS"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const embedding = item.json.data?.[0]?.embedding;\n  if (!embedding) {\n    item.json.error = 'No se pudo generar el embedding';\n    return item;\n  }\n  item.json.embedding_vector = JSON.stringify(embedding);\n  return item;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1220,
        240
      ],
      "id": "0644fc14-995c-438d-9e0a-9bb813af4785",
      "name": "EXTRAE VECTOR"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ (() => {\n  const vector = $json.embedding_vector;\n  const mod = $json.modalidad_filtro;\n  const modParam = mod ? `'${mod.replace(/'/g, \"''\")}'` : 'NULL';\n  return `SELECT * FROM buscar_conocimiento_utpl('${vector}'::vector, ${modParam}, 3);`;\n})() }}",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1440,
        240
      ],
      "id": "5cba8f7c-9f7d-4e55-aed8-257ba4a335f0",
      "name": "BUSCAR EN SUPABASE",
      "credentials": {
        "postgres": {
          "id": "Iz7EEp0WgJu3LXhn",
          "name": "Gea_postgress"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const rows = $items('BUSCAR EN SUPABASE', 0, 0).filter(r => r.json.id);\n  const toolCallId = $items('PREPARA EMBEDDING', 0, 0)[0]?.json?.toolCallId || '';\n\n  let respuesta = '';\n  if (rows.length === 0) {\n    respuesta = 'No encontre informacion sobre eso en la base de conocimiento. Indica al estudiante que puedes agendarle con un ejecutivo de UTPL para mas informacion.';\n  } else {\n    const contexto = rows.map((r, i) =>\n      `[${i + 1}] (${r.json.fuente || 'general'}) ${r.json.contenido}`\n    ).join('\\n\\n');\n    respuesta = contexto + '\\n\\nInstruccion: Usa esta informacion para responder al estudiante de forma natural, clara y amigable. No inventes datos. Si la info es insuficiente, consulta agendar a un ejecutivo de UTPL .';\n  }\n\n  return { json: {\n    results: [{\n      toolCallId: toolCallId,\n      result: respuesta\n    }]\n  }};\n});"
      },
